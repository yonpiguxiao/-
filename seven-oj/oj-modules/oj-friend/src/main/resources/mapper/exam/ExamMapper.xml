<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTO Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seven.friend.mapper.exam.ExamMapper">
    <select id="selectExamList" resultType="com.seven.friend.domain.exam.vo.ExamVO">
        SELECT
            te.exam_id,
            te.title,
            te.start_time,
            te.end_time
        FROM
            tb_exam te
        where
            status = 1
            <if test="title != null and title != '' ">
                AND te.title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="startTime != null and startTime != '' ">
                AND te.start_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != '' ">
                AND te.end_time &lt;= #{endTime}
            </if>
            <if test="type == 0">
                AND te.end_time > NOW()
            </if>
            <if test="type == 1">
                AND te.end_time &lt;= NOW()
            </if>
        ORDER BY
            te.create_time DESC
    </select>
</mapper>