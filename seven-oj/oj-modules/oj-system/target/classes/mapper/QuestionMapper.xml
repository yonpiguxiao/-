<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTO Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.seven.system.mapper.question.QuestionMapper">
    <select id="selectQuestionList" resultType="com.seven.system.domain.question.vo.QuestionVO">
        SELECT
            tq.question_id,
            tq.title,
            tq.difficulty,
            ts.nick_name as create_name,
            ts.create_time
        FROM
            tb_question tq
        left join
            tb_sys_user ts
        on
            tq.create_by = ts.user_id
        <where>
            <if test="difficulty != null">
                AND difficulty = #{difficulty}
            </if>
            <if test="title != null and title != '' ">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
        </where>
        ORDER BY
        create_time DESC
    </select>
</mapper>